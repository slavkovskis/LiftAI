@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using LiftAI.Shared.Models.Dtos
@using LiftAI.Shared.Models.Dtos.Email
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<ForgotPassword> Logger

<PageTitle>Forgot Password - LiftAI</PageTitle>

<section class="auth-page">
    <div class="auth-page__panel">
        <h1 class="mb-2">Forgot your password?</h1>
        <p class="text-muted mb-0">Enter your email and we will send you a reset link.</p>
    </div>

    <div class="auth-card">
        <EditForm Model="_form" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mb-3">
                <label for="email">Email *</label>
                <InputText id="email" type="email" required
                           @bind-Value="_form.Email"
                           class="form-control"
                           autocomplete="email" />
                <ValidationMessage For="() => _form.Email" />
            </div>

            <button type="submit" class="btn btn-primary auth-card__submit" disabled="@_isLoading">
                @(_isLoading ? "Sending link..." : "Send reset link")
            </button>
        </EditForm>

        <p class="mt-3 mb-0 text-muted">
            Remembered your password? <a href="/login">Back to login</a>
        </p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="mt-3 @_messageClass">
                @_message
            </div>
        }
    </div>
</section>

@code {
    private sealed class ForgotPasswordForm
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
    }

    private readonly ForgotPasswordForm _form = new();
    private bool _isLoading;
    private string? _message;
    private string _messageClass = "";

    private async Task HandleSubmitAsync()
    {
        _isLoading = true;
        _message = null;
        _messageClass = "";

        try
        {
            var api = HttpClientFactory.CreateClient("Api");
            var dto = new ForgotPasswordRequestDto { Email = _form.Email };

            var httpResponse = await api.PostAsJsonAsync("api/auth/forgot-password", dto);
            var result = await httpResponse.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (httpResponse.IsSuccessStatusCode && result?.Success == true)
            {
                _message = result.Message ?? "If the email exists, a reset link was sent.";
                _messageClass = "text-success";
                return;
            }

            _message = result?.Message ?? "Unable to send reset link. Please try again.";
            _messageClass = "text-danger";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Forgot password request failed");
            _message = "An unexpected error occurred. Please try again.";
            _messageClass = "text-danger";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

