@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using LiftAI.Shared.Models.Dtos
@using LiftAI.Shared.Models.Dtos.Email
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject ILogger<ResetPassword> Logger

<PageTitle>Reset Password - LiftAI</PageTitle>

<section class="auth-page">
    <div class="auth-page__panel">
        <h1 class="mb-2">Reset your password</h1>
        <p class="text-muted mb-0">Choose a new password for your account.</p>
    </div>

    <div class="auth-card">
        @if (IsMissingQuery)
        {
            <div class="text-danger mb-3">
                The reset link is missing required information. Please request a new link.
            </div>
        }

        <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mb-3">
                <label for="email">Email</label>
                <InputText id="email" type="email" required
                           @bind-Value="_form.Email"
                           class="form-control"
                           autocomplete="email"
                           readonly />
                <ValidationMessage For="() => _form.Email" />
            </div>

            <InputText id="token" type="hidden" @bind-Value="_form.Token" />

            <div class="form-group mb-3">
                <label for="newPassword">New password</label>
                <InputText id="newPassword" type="password" required
                           @bind-Value="_form.NewPassword"
                           class="form-control"
                           autocomplete="new-password" />
                <ValidationMessage For="() => _form.NewPassword" />
            </div>

            <div class="form-group mb-3">
                <label for="confirmPassword">Confirm password</label>
                <InputText id="confirmPassword" type="password" required
                           @bind-Value="_form.ConfirmPassword"
                           class="form-control"
                           autocomplete="new-password" />
                <ValidationMessage For="() => _form.ConfirmPassword" />
            </div>

            <button type="submit" class="btn btn-primary auth-card__submit" disabled="@(_isLoading || IsMissingQuery)">
                @(_isLoading ? "Resetting..." : "Reset password")
            </button>
        </EditForm>

        <p class="mt-3 mb-0 text-muted">
            Remembered your password? <a href="/login">Back to login</a>
        </p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="mt-3 @_messageClass">
                @_message
            </div>
        }
    </div>
</section>

@code {
    private sealed class ResetPasswordForm
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Token { get; set; } = string.Empty;

        [Required, MinLength(6)]
        public string NewPassword { get; set; } = string.Empty;

        [Required, Compare(nameof(NewPassword))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    [Parameter, SupplyParameterFromQuery]
    public string? Email { get; set; }

    [Parameter, SupplyParameterFromQuery]
    public string? Token { get; set; }

    private readonly ResetPasswordForm _form = new();
    private readonly EditContext _editContext;
    private FieldIdentifier _confirmField;
    private bool _isLoading;
    private string? _message;
    private string _messageClass = "";

    private bool IsMissingQuery => string.IsNullOrWhiteSpace(_form.Email) || string.IsNullOrWhiteSpace(_form.Token);

    public ResetPassword()
    {
        _editContext = new EditContext(_form);
        _confirmField = new FieldIdentifier(_form, nameof(ResetPasswordForm.ConfirmPassword));
        _editContext.OnFieldChanged += HandleFieldChanged;
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Email))
        {
            _form.Email = Email;
        }

        if (!string.IsNullOrWhiteSpace(Token))
        {
            _form.Token = Token;
        }
    }

    private void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        if (e.FieldIdentifier.FieldName == nameof(ResetPasswordForm.NewPassword))
        {
            _editContext.NotifyFieldChanged(_confirmField);
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (IsMissingQuery)
        {
            _message = "The reset link is missing required information.";
            _messageClass = "text-danger";
            return;
        }

        _isLoading = true;
        _message = null;
        _messageClass = "";

        try
        {
            var api = HttpClientFactory.CreateClient("Api");
            var dto = new ResetPasswordRequestDto
            {
                Email = _form.Email,
                Token = _form.Token,
                NewPassword = _form.NewPassword
            };

            var httpResponse = await api.PostAsJsonAsync("api/auth/reset-password", dto);
            var result = await httpResponse.Content.ReadFromJsonAsync<AuthResponseDto>();

            if (httpResponse.IsSuccessStatusCode && result?.Success == true)
            {
                _message = result.Message ?? "Password reset successful. You can now log in.";
                _messageClass = "text-success";

                await Task.Delay(1500);
                Navigation.NavigateTo("/login");
                return;
            }

            _message = result?.Message ?? "Password reset failed. Please try again.";
            _messageClass = "text-danger";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Password reset failed");
            _message = "An unexpected error occurred. Please try again.";
            _messageClass = "text-danger";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
