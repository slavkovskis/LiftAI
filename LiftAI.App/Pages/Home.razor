@page "/"

<PageTitle>Home</PageTitle>

<section class="home-page">
    <div class="home-hero">
        <div class="home-hero__badge">LiftAI</div>
        <h1 class="home-hero__title">Train smarter and log every set with confidence.</h1>
        <p class="home-hero__subtitle">A smooth workout tracker with AI support and simple logging.</p>
        <div class="home-hero__cta">
            <a class="btn btn-primary btn-lg" href="/workouts/log">Start workout</a>
            <a class="btn btn-outline-secondary btn-lg" href="/workouts">View history</a>
        </div>
        <div class="home-hero__glow"></div>
    </div>

    <div class="home-page__actions">
        <a class="home-card" href="/workouts/log">
            <span class="home-card__icon" aria-hidden="true">
                <i class="bi bi-play-circle"></i>
            </span>
            <h2>Start a new workout</h2>
            <p>Open the logger, add exercises, and track sets with rest timers.</p>
            <span class="home-card__cta">
                <span>Open workout logger</span>
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </span>
        </a>

        <a class="home-card" href="/workouts">
            <span class="home-card__icon" aria-hidden="true">
                <i class="bi bi-clock-history"></i>
            </span>
            <h2>View previous workouts</h2>
            <p>Review your training history and revisit session details.</p>
            <span class="home-card__cta">
                <span>Open workout history</span>
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </span>
        </a>

        <a class="home-card" href="/exercises">
            <span class="home-card__icon" aria-hidden="true">
                <i class="bi bi-clipboard-pulse"></i>
            </span>
            <h2>View your exercises</h2>
            <p>Browse available exercises and their default rest settings.</p>
            <span class="home-card__cta">
                <span>Open exercises</span>
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </span>
        </a>

        <a class="home-card" href="/chat">
            <span class="home-card__icon" aria-hidden="true">
                <i class="bi bi-chat-left-text"></i>
            </span>
            <h2>Chat with AI</h2>
            <p>Ask for workout splits, form tips, and personalized advice.</p>
            <span class="home-card__cta">
                <span>Open chat</span>
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </span>
        </a>
    </div>
</section>