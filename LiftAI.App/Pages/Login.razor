@page "/login"
@using LiftAI.App.Auth
@using LiftAI.Shared.Models.Dtos
@inject IHttpClientFactory HttpClientFactory
@inject JwtAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Login - LiftAI</PageTitle>

<section class="auth-page">
    <div class="auth-page__panel">
        <h1 class="mb-2">Welcome back</h1>
        <p class="text-muted mb-0">Log in to continue tracking your workouts.</p>
    </div>

    <div class="auth-card">
        <EditForm Model="_loginModel" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group mb-3">
                <label for="email">Email</label>
                <InputText id="email"
                           @bind-Value="_loginModel.Email"
                           class="form-control"
                           autocomplete="email" />
                <ValidationMessage For="() => _loginModel.Email" />
            </div>

            <div class="form-group mb-3">
                <label for="password">Password</label>
                <InputText id="password"
                           type="password"
                           @bind-Value="_loginModel.Password"
                           class="form-control"
                           autocomplete="current-password" />
                <ValidationMessage For="() => _loginModel.Password" />
            </div>

            <button type="submit" class="btn btn-primary auth-card__submit" disabled="@_isLoading">
                @(_isLoading ? "Logging in..." : "Login")
            </button>
        </EditForm>

        <p class="mt-2 mb-0 text-muted">
            <a href="/forgot-password">Forgot your password?</a>
        </p>

        <p class="mt-3 mb-0 text-muted">
            Do not have an account? <a href="/register">Create one</a>
        </p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="mt-3 @_messageClass">
                @_message
            </div>
        }
    </div>
</section>

@code {
    private readonly LoginDto _loginModel = new();
    private bool _isLoading;
    private string? _message;
    private string _messageClass = "";

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _message = null;
        _messageClass = "";

        try
        {
            var api = HttpClientFactory.CreateClient("Api");

            var httpResponse = await api.PostAsJsonAsync("api/auth/login", _loginModel);

            if (httpResponse.IsSuccessStatusCode)
            {
                var result = await httpResponse.Content.ReadFromJsonAsync<AuthResponseDto>();

                if (result?.Success == true && !string.IsNullOrWhiteSpace(result.Token))
                {
                    await AuthProvider.MarkUserAsAuthenticated(result.Token);

                    _message = "Login successful!";
                    _messageClass = "text-success";

                    Navigation.NavigateTo("/", forceLoad: true);
                    return;
                }
            }

            var errorResult = await httpResponse.Content.ReadFromJsonAsync<AuthResponseDto>();
            _message = errorResult?.Message ?? "Invalid email or password.";
            _messageClass = "text-danger";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Login failed unexpectedly");
            _message = "An unexpected error occurred. Please try again.";
            _messageClass = "text-danger";
        }
        finally
        {
            _isLoading = false;
        }
    }
}