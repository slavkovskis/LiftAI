@using LiftAI.App.Models
@using LiftAI.App.Services
@inject ActiveWorkoutState ActiveWorkoutState

<div class="exercise-card card mb-3">
    <button type="button"
            class="exercise-card__toggle card-body"
            @onclick="ToggleExpanded"
            aria-expanded="@_isExpanded"
            aria-controls="@DetailsId">
        <div class="d-flex justify-content-between align-items-center gap-3">
            <div class="exercise-card__summary">
                <h5 class="card-title mb-0">@Exercise.ExerciseName</h5>

                <span class="exercise-card__set-count text-muted">
                    @Exercise.Sets.Count set@(Exercise.Sets.Count == 1 ? string.Empty : "s")
                </span>
            </div>

            <span class="exercise-card__chevron text-muted" aria-hidden="true">
                @(_isExpanded ? "▴" : "▾")
            </span>
        </div>
    </button>

    @if (_isExpanded)
    {
        <div class="card-body pt-0" id="@DetailsId">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div class="exercise-card__actions">
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            @onclick="AddSet">
                        + Add Set
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            @onclick="RemoveExercise">
                        Remove
                    </button>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label">Exercise Notes</label>
                <InputTextArea class="form-control"
                               rows="2"
                               placeholder="These notes are saved to the exercise description"
                               @bind-Value="Exercise.Description"
                               @bind-Value:after="NotifyExerciseDescriptionChanged" />
            </div>

            <div class="mt-3">
                @if (Exercise.Sets.Count == 0)
                {
                    <p class="text-muted mb-0">No sets yet.</p>
                }
                else
                {
                    @for (var i = 0; i < Exercise.Sets.Count; i++)
                    {
                        var setIndex = i;
                        var set = Exercise.Sets[setIndex];

                        <SetRow @key="set"
                                Set="set"
                                IsTimed="Exercise.IsTimed"
                                OnChanged="updatedSet => HandleSetChanged(setIndex, updatedSet)"
                                OnDeleteRequested="() => HandleSetDeleted(setIndex)" />
                    }
                }
            </div>
        </div>
    }

</div>

@code {
    [Parameter, EditorRequired]
    public WorkoutExerciseVm Exercise { get; set; } = default!;

    [Parameter, EditorRequired]
    public int ExerciseIndex { get; set; }

    [Parameter]
    public EventCallback<int> OnRestTriggered { get; set; }

    private bool _isExpanded;

    private string DetailsId => $"exercise-details-{ExerciseIndex}";

    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }

    private async Task AddSet()
    {
        var shouldTriggerRest = Exercise.Sets.Count > 0;
        ActiveWorkoutState.AddSet(ExerciseIndex);

        if (shouldTriggerRest && OnRestTriggered.HasDelegate)
        {
            await OnRestTriggered.InvokeAsync(Exercise.DefaultRestSeconds);
        }
    }

    private void RemoveExercise()
    {
        ActiveWorkoutState.RemoveExercise(ExerciseIndex);
    }

    private void HandleSetChanged(int setIndex, ExerciseSetVm updatedSet)
    {
        ActiveWorkoutState.UpdateSet(ExerciseIndex, setIndex, updatedSet);
    }


    private Task HandleSetDeleted(int setIndex)
    {
        ActiveWorkoutState.RemoveSet(ExerciseIndex, setIndex);
        return Task.CompletedTask;
    }

    private Task NotifyExerciseDescriptionChanged()
    {
        ActiveWorkoutState.UpdateExerciseDescription(ExerciseIndex, Exercise.Description);
        return Task.CompletedTask;
    }

}