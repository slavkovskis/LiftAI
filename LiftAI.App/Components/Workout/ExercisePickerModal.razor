@using LiftAI.App.Services
@using LiftAI.Shared.Models.Dtos.Exercise
@inject ExerciseService ExerciseService

@if (IsOpen)
{
    <div class="workout-modal-backdrop" @onclick="CloseAsync">
        <section class="workout-modal-panel" @onclick:stopPropagation="true">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Add Exercise</h5>

                <button type="button" class="btn-close" aria-label="Close" @onclick="CloseAsync"></button>
            </div>

            <input class="form-control mb-3"
                   placeholder="Search exercises..."
                   @bind="_searchText"
                   @bind:event="oninput" />

            @if (_isLoading)
            {
                <p class="text-muted mb-0">Loading exercises...</p>
            }
            else if (FilteredExercises.Count == 0)
            {
                <p class="text-muted mb-0">No matching exercises.</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var exercise in FilteredExercises)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action"
                                @onclick="() => SelectExerciseAsync(exercise)">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">@exercise.Name</div>
                                    <div class="small text-muted">@exercise.MuscleGroup</div>
                                </div>

                                <span class="badge text-bg-secondary">
                                    @(exercise.IsTimed ? "Timed" : "Reps")
                                </span>
                            </div>
                        </button>
                    }
                </div>
            }

            <div class="mt-3 text-end">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">
                    Cancel
                </button>
            </div>
        </section>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<ExerciseDto> OnExerciseSelected { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private List<ExerciseDto> _allExercises = [];
    private string _searchText = string.Empty;
    private bool _isLoading;
    private bool _loadedOnce;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || _loadedOnce)
        {
            return;
        }

        _isLoading = true;

        try
        {
            _allExercises = await ExerciseService.GetAllExercisesAsync();
            _loadedOnce = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private List<ExerciseDto> FilteredExercises =>
        _allExercises
            .Where(exercise =>
                string.IsNullOrWhiteSpace(_searchText) ||
                exercise.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                exercise.MuscleGroup.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (exercise.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderBy(exercise => exercise.Name)
            .ToList();

    private async Task SelectExerciseAsync(ExerciseDto exercise)
    {
        await OnExerciseSelected.InvokeAsync(exercise);
    }

    private async Task CloseAsync()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }
}